# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# Env variables extracted from shared to be exposed to the client in Next.js app
NEXT_PUBLIC_PRODUCT_NAME="${PRODUCT_NAME}"
NEXT_PUBLIC_URL="${URL}"
NEXT_PUBLIC_DEFAULT_LOCALE="${DEFAULT_LOCALE}"


#########################
###    Auth config    ###
#########################

# Auth server secret - used to sign the tokens
BETTER_AUTH_SECRET="lT4GdPj3OSx00OcTRUdwywn1DNgBBuvK"
BETTER_AUTH_URL="${NEXT_PUBLIC_URL}"

# OAuth providers
GOOGLE_CLIENT_ID="<your-google-client-id>"
GOOGLE_CLIENT_SECRET="<your-google-client-secret>"

GITHUB_CLIENT_ID="<your-github-client-id>"
GITHUB_CLIENT_SECRET="<your-github-client-secret>"


##########################
###   Billing config   ###
##########################

# Stripe
STRIPE_SECRET_KEY="<your-stripe-secret-key>"
STRIPE_WEBHOOK_SECRET="<your-stripe-webhook-signing-secret>"


#############################
###    OpenClaw config    ###
#############################

# Fly Machines settings
FLY_API_TOKEN="<your-fly-api-token>"
FLY_ORG_SLUG="personal"
FLY_REGION="iad"
FLY_OPENCLAW_IMAGE="ghcr.io/openclaw/openclaw:2026.3.7"
FLY_MACHINE_CPUS="2"
FLY_MACHINE_MEMORY_MB="3072"
FLY_VOLUME_SIZE_GB="1"
FLY_OPENCLAW_STATE_DIR="/data"

# VPS + Caddy instance routing settings
VPS_HOST="<your-vps-host>"
VPS_SSH_PORT="22"
VPS_USER="root"
VPS_PRIVATE_KEY="<your-ssh-private-key-with-escaped-newlines>"
VPS_PRIVATE_KEY_PASSPHRASE=""
VPS_OPENCLAW_STATE_DIR="/var/lib/openclaw"
VPS_OPENCLAW_IMAGE="ghcr.io/openclaw/openclaw:2026.3.7"
VPS_INSTANCE_DOMAIN_SUFFIX="openclaw.your-domain.com"
VPS_CADDY_ROUTES_DIR="/etc/caddy/routes"
VPS_CADDY_CONFIG_PATH="/etc/caddy/Caddyfile"
VPS_CONTAINER_MEMORY="3g"
VPS_CONTAINER_CPUS="1.5"

# GCP instance-per-user settings
GCP_CREDENTIALS=""
GCP_PROJECT_ID="<your-gcp-project-id>"
GCP_ZONE="us-central1-a"
GCP_OPENCLAW_STATE_DIR="/var/lib/openclaw"
GCP_INSTANCE_TEMPLATE_NAME="openclaw-gateway-template"
GCP_INSTANCE_DOMAIN_SUFFIX=""

# AI provider keys used by instance deployment
OPENAI_API_KEY="<your-openai-api-key>"
ANTHROPIC_API_KEY="<your-anthropic-api-key>"
GOOGLE_GENERATIVE_AI_API_KEY="<your-google-generative-ai-api-key>"
