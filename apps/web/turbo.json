{
  "$schema": "https://turborepo.org/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "next-env.d.ts"],
      "env": [
        "DATABASE_URL",

        "BETTER_AUTH_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",

        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",

        "FLY_API_TOKEN",
        "FLY_ORG_SLUG",
        "FLY_REGION",
        "FLY_OPENCLAW_IMAGE",
        "FLY_MACHINE_CPUS",
        "FLY_MACHINE_MEMORY_MB",
        "FLY_VOLUME_SIZE_GB",
        "FLY_OPENCLAW_STATE_DIR",

        "VPS_HOST",
        "VPS_SSH_PORT",
        "VPS_USER",
        "VPS_PRIVATE_KEY",
        "VPS_PRIVATE_KEY_PASSPHRASE",
        "VPS_OPENCLAW_STATE_DIR",
        "VPS_OPENCLAW_IMAGE",
        "VPS_INSTANCE_DOMAIN_SUFFIX",
        "VPS_CADDY_ROUTES_DIR",
        "VPS_CADDY_CONFIG_PATH",
        "VPS_CONTAINER_MEMORY",
        "VPS_CONTAINER_CPUS",

        "GCP_CREDENTIALS",
        "GCP_PROJECT_ID",
        "GCP_ZONE",
        "GCP_OPENCLAW_STATE_DIR",
        "GCP_INSTANCE_TEMPLATE_NAME",
        "GCP_INSTANCE_DOMAIN_SUFFIX",

        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "GOOGLE_GENERATIVE_AI_API_KEY"
      ]
    },
    "dev": {
      "persistent": true
    }
  }
}
