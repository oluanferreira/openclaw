FROM ghcr.io/openclaw/openclaw:latest

USER root

RUN apt-get update && apt-get install -y --no-install-recommends     python3-pip     ffmpeg     jq     tesseract-ocr     && apt-get clean     && rm -rf /var/lib/apt/lists/*

# yt-dlp via pip (mais atualizado que apt)
RUN pip3 install --break-system-packages yt-dlp

USER node
